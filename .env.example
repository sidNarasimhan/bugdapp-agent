# Required — core agent
OPENROUTER_API_KEY=sk-or-v1-...
SEED_PHRASE=test test test test test test test test test test test junk
METAMASK_PATH=/absolute/path/to/metamask-extension
METAMASK_SEED_PHRASE=test test test test test test test test test test test junk

# Optional — MetaMask password (default used if absent)
METAMASK_PASSWORD=Web3QaAgent!2026

# Optional — forked-chain execution
FOUNDRY_BIN=/path/to/foundry/bin
CDP_URL=http://127.0.0.1:18800

# Optional — planner LLM model (default deepseek/deepseek-chat)
PLAN_MODEL=deepseek/deepseek-chat

# --- Chat bots ---
# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_APP_ID=

# Slack (socket mode — no public URL needed)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=

# --- Findings integration ---
# Notion (https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=

# --- Legacy / optional integrations ---
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
LINEAR_API_KEY=
LINEAR_TEAM_ID=
